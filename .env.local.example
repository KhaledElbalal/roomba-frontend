# Roomba frontend env — copy to .env.local and fill in real values.
# .env* is gitignored (see .gitignore). Never commit real secrets.

# --- Neon Auth (server-side only — never exposed to the browser) ---
# Base URL of your hosted Neon Auth instance. Confirm from the Neon Console.
# Example: https://ep-xxxx.neonauth.us-east-1.aws.neon.tech
NEON_AUTH_BASE_URL=https://your-neon-auth-instance.neon.tech

# Secret used to sign Neon Auth session cookies. MUST be at least 32 characters.
# Generate a strong random value (e.g. `openssl rand -base64 32`).
NEON_AUTH_COOKIE_SECRET=replace-with-a-random-string-at-least-32-chars

# --- Cross-service (public, non-secret) ---
# Base URL of the Rails backend. The /api/me round-trip goes to ${NEXT_PUBLIC_API_URL}/api/me.
NEXT_PUBLIC_API_URL=http://localhost:3000
